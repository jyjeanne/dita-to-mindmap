{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jyjeanne/dita-to-mindmap/schemas/jsmind-node-tree.schema.json",
  "title": "jsMind node_tree format",
  "description": "Schema for jsMind mindmap data in node_tree format, as generated by the DITA-OT mindmap plugin.",
  "type": "object",
  "required": ["meta", "format", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the mindmap"
        }
      }
    },
    "format": {
      "type": "string",
      "const": "node_tree",
      "description": "Must be 'node_tree' for this format"
    },
    "data": {
      "$ref": "#/$defs/node"
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "topic", "expanded"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier for this node"
        },
        "topic": {
          "type": "string",
          "minLength": 1,
          "description": "Display text for this node"
        },
        "expanded": {
          "type": "boolean",
          "description": "Whether the node is initially expanded"
        },
        "direction": {
          "type": "string",
          "enum": ["left", "right"],
          "description": "Branch direction for bilateral layout (root children only)"
        },
        "data": {
          "type": "object",
          "description": "Optional styling and metadata for the node",
          "additionalProperties": false,
          "properties": {
            "background-color": {
              "type": "string",
              "pattern": "^(#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?|[a-zA-Z]+)$",
              "description": "Node background color (hex or named)"
            },
            "foreground-color": {
              "type": "string",
              "pattern": "^(#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?|[a-zA-Z]+)$",
              "description": "Node text color (hex or named)"
            },
            "font-weight": {
              "type": "string",
              "enum": ["normal", "bold"],
              "description": "Font weight for the node label"
            },
            "leading-line-color": {
              "type": "string",
              "pattern": "^(#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?|[a-zA-Z]+)$",
              "description": "Color of the connector line leading to this node"
            },
            "icon": {
              "type": "string",
              "minLength": 1,
              "description": "Icon identifier for the node"
            },
            "url": {
              "type": "string",
              "minLength": 1,
              "description": "Hyperlink URL associated with the node"
            }
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          },
          "minItems": 1,
          "description": "Child nodes (only present if the node has children)"
        }
      }
    }
  }
}
